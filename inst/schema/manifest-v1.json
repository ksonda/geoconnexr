{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ksonda.github.io/geoconnexr/schema/manifest-v1.json",
  "title": "geoconnexr snapshot manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "manifest_version",
    "package",
    "created_at",
    "recipe",
    "replay",
    "endpoints",
    "asset_hashes",
    "requests",
    "resources",
    "completeness",
    "session"
  ],
  "properties": {
    "contract_version": {"const": "1.0.0"},
    "manifest_version": {"const": "1.0.0"},
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {"const": "geoconnexr"},
        "version": {"type": "string", "minLength": 1}
      }
    },
    "created_at": {"type": "string", "format": "date-time"},
    "recipe": {"$ref": "recipe-v1.json"},
    "replay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["replayable", "non_replayable_reasons", "handler_versions"],
      "properties": {
        "replayable": {"type": "boolean"},
        "non_replayable_reasons": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string"}
        },
        "handler_versions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["handler", "implementation_id", "version", "replayable"],
            "properties": {
              "handler": {"type": "string", "minLength": 1},
              "implementation_id": {"type": "string", "minLength": 1},
              "version": {"type": "string", "minLength": 1},
              "replayable": {"type": "boolean"}
            }
          }
        }
      }
    },
    "effective_options": {"type": "object"},
    "endpoints": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {"minLength": 1},
      "additionalProperties": {"type": "string", "format": "uri"}
    },
    "hydrologic_vintage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reference_collection": {"type": "string"},
        "vintage": {"type": "string"},
        "migration_policy": {"type": "string"}
      }
    },
    "asset_hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["queries", "handler_registry", "vocabulary"],
      "properties": {
        "queries": {"$ref": "#/$defs/sha256"},
        "handler_registry": {"$ref": "#/$defs/sha256"},
        "vocabulary": {"$ref": "#/$defs/sha256"}
      }
    },
    "requests": {
      "type": "array",
      "maxItems": 10000,
      "items": {"$ref": "#/$defs/request"}
    },
    "resources": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10000,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/resource"}
    },
    "completeness": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["stage", "status", "truncated"],
        "properties": {
          "stage": {"type": "string", "minLength": 1},
          "status": {"enum": ["complete", "partial", "not_run", "unknown"]},
          "truncated": {"type": "boolean"},
          "reason": {"type": "string"}
        }
      }
    },
    "source_licenses": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_uri", "status"],
        "properties": {
          "source_uri": {"type": "string", "format": "uri"},
          "license_uri": {"type": ["string", "null"], "format": "uri"},
          "status": {"enum": ["declared", "missing", "unknown"]}
        }
      }
    },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": ["r_version", "platform", "locale"],
      "properties": {
        "r_version": {"type": "string"},
        "platform": {"type": "string"},
        "locale": {"type": "string"},
        "packages": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["package", "version"],
            "properties": {
              "package": {"type": "string"},
              "version": {"type": "string"}
            }
          }
        }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64,
      "pattern": "^[a-f0-9]{64}$"
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_id", "stage", "method", "canonical_url_redacted",
        "request_hash", "retrieved_at", "cache_origin"
      ],
      "properties": {
        "request_id": {"type": "string", "minLength": 1},
        "stage": {"type": "string", "minLength": 1},
        "method": {"enum": ["GET", "HEAD", "POST"]},
        "canonical_url_redacted": {"type": "string", "minLength": 1},
        "request_hash": {"$ref": "#/$defs/sha256"},
        "body_hash": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
        "final_url": {"type": ["string", "null"], "format": "uri"},
        "response_status": {"type": ["integer", "null"], "minimum": 100, "maximum": 599},
        "response_media_type": {"type": ["string", "null"]},
        "encoded_bytes": {"type": ["integer", "null"], "minimum": 0, "maximum": 1073741824},
        "decoded_bytes": {"type": ["integer", "null"], "minimum": 0, "maximum": 1073741824},
        "content_hash": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
        "etag": {"type": ["string", "null"]},
        "last_modified": {"type": ["string", "null"]},
        "retrieved_at": {"type": "string", "format": "date-time"},
        "elapsed_ms": {"type": ["number", "null"], "minimum": 0},
        "cache_origin": {"enum": ["network", "fresh_cache", "offline_cache"]},
        "error_code": {"type": ["string", "null"]}
      }
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "media_type", "bytes", "sha256", "required", "roles"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024,
          "pattern": "^(?!manifest[.]json$)(?!.*(?:^|/)[.]{1,2}(?:/|$))(?!.*(?:^|/)(?:[Cc][Oo][Nn]|[Pp][Rr][Nn]|[Aa][Uu][Xx]|[Nn][Uu][Ll]|[Cc][Oo][Mm][1-9]|[Ll][Pp][Tt][1-9])(?:[.]|/|$))[A-Za-z0-9_-](?:[A-Za-z0-9._-]{0,253}[A-Za-z0-9_-])?(?:/[A-Za-z0-9_-](?:[A-Za-z0-9._-]{0,253}[A-Za-z0-9_-])?){0,15}$"
        },
        "media_type": {"type": "string", "minLength": 1},
        "bytes": {"type": "integer", "minimum": 0, "maximum": 1073741824},
        "sha256": {"$ref": "#/$defs/sha256"},
        "required": {"type": "boolean"},
        "roles": {"type": "array", "minItems": 1, "maxItems": 16, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "source_uri": {"type": ["string", "null"], "format": "uri"},
        "license_uri": {"type": ["string", "null"], "format": "uri"}
      }
    }
  }
}
