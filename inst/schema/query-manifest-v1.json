{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ksonda.github.io/geoconnexr/schema/query-manifest-v1.json",
  "title": "geoconnexr named-query manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "contract_version", "templates"],
  "properties": {
    "version": {"const": 1},
    "contract_version": {"const": "0.1.0"},
    "endpoint_policy": {"type": "object"},
    "defaults": {"type": "object"},
    "templates": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"$ref": "#/$defs/template"}
    }
  },
  "$defs": {
    "parameter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "required"],
      "properties": {
        "type": {"enum": ["uri", "uri_list", "wkt", "integer"]},
        "required": {"type": "boolean"},
        "minimum": {"type": "integer"},
        "maximum": {"type": "integer"},
        "minimum_items": {"type": "integer", "minimum": 1},
        "maximum_items": {"type": "integer", "minimum": 1}
      }
    },
    "template": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "query_type", "parameters", "stable_order", "page_strategy", "result_key", "row_budget"],
      "properties": {
        "file": {"type": "string", "pattern": "^[A-Za-z0-9_-]+\\.rq$"},
        "query_type": {"const": "select"},
        "parameters": {"type": "object", "additionalProperties": {"$ref": "#/$defs/parameter"}},
        "stable_order": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"}},
        "page_strategy": {"enum": ["offset"]},
        "result_key": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "row_budget": {"type": "integer", "minimum": 1}
      }
    }
  }
}
