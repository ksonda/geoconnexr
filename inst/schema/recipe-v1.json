{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ksonda.github.io/geoconnexr/schema/recipe-v1.json",
  "title": "geoconnexr replay recipe v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "aoi", "pipeline"],
  "properties": {
    "contract_version": {"const": "1.0.0"},
    "aoi": {"$ref": "#/$defs/aoi"},
    "pipeline": {"$ref": "#/$defs/pipeline"},
    "time": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["start", "end"],
          "properties": {
            "start": {"type": ["string", "null"], "format": "date-time"},
            "end": {"type": ["string", "null"], "format": "date-time"}
          }
        }
      ]
    },
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "include": {
          "type": "array",
          "uniqueItems": true,
          "items": {"enum": ["sites", "datasets", "reference"]}
        },
        "providers": {"$ref": "#/$defs/string_array"},
        "variables": {"$ref": "#/$defs/string_array"}
      }
    },
    "fetch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {"type": "boolean"},
        "max_datasets": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
        "max_requests": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
        "max_encoded_bytes": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
        "max_decoded_bytes": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
        "handler_order": {"$ref": "#/$defs/string_array"}
      }
    },
    "harmonize": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {"type": "boolean"},
        "target_units": {
          "type": "object",
          "additionalProperties": {"type": "string", "format": "uri"}
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "timeseries": {"enum": ["csv", "parquet"]},
        "keep_raw": {"type": "boolean"},
        "report": {"type": "boolean"}
      }
    }
  },
  "$defs": {
    "string_array": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "pipeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_stage", "end_stage"],
      "properties": {
        "start_stage": {"enum": ["aoi", "catalog", "fetched", "harmonized"]},
        "end_stage": {"enum": ["catalog", "fetched", "harmonized", "package"]}
      },
      "allOf": [
        {
          "if": {"properties": {"start_stage": {"const": "catalog"}}, "required": ["start_stage"]},
          "then": {"properties": {"end_stage": {"enum": ["fetched", "harmonized", "package"]}}}
        },
        {
          "if": {"properties": {"start_stage": {"const": "fetched"}}, "required": ["start_stage"]},
          "then": {"properties": {"end_stage": {"enum": ["harmonized", "package"]}}}
        },
        {
          "if": {"properties": {"start_stage": {"const": "harmonized"}}, "required": ["start_stage"]},
          "then": {"properties": {"end_stage": {"const": "package"}}}
        }
      ]
    },
    "aoi": {
      "oneOf": [
        {"$ref": "#/$defs/id_aoi"},
        {"$ref": "#/$defs/geometry_aoi"}
      ]
    },
    "id_aoi": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "identifier"],
          "properties": {
            "kind": {"const": "huc"},
            "identifier": {
              "type": "string",
              "pattern": "^([0-9]{2}|[0-9]{4}|[0-9]{6}|[0-9]{8}|[0-9]{10}|[0-9]{12})$"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "identifier"],
          "properties": {
            "kind": {"const": "county"},
            "identifier": {"type": "string", "pattern": "^[0-9]{5}$"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "identifier"],
          "properties": {
            "kind": {"const": "state"},
            "identifier": {
              "enum": [
                "AL", "AK", "AZ", "AR", "CA", "CO", "CT", "DE", "FL", "GA",
                "HI", "ID", "IL", "IN", "IA", "KS", "KY", "LA", "ME", "MD",
                "MA", "MI", "MN", "MS", "MO", "MT", "NE", "NV", "NH", "NJ",
                "NM", "NY", "NC", "ND", "OH", "OK", "OR", "PA", "RI", "SC",
                "SD", "TN", "TX", "UT", "VT", "VA", "WA", "WV", "WI", "WY",
                "DC", "AS", "GU", "MP", "PR", "UM", "VI"
              ]
            }
          }
        }
      ]
    },
    "geometry_aoi": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "canonical_geojson", "crs", "wkb_sha256"],
      "properties": {
        "kind": {"const": "sf"},
        "canonical_geojson": {"$ref": "#/$defs/geojson_geometry"},
        "crs": {"const": "OGC:CRS84"},
        "wkb_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "geojson_geometry": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "coordinates"],
          "properties": {
            "type": {"const": "Polygon"},
            "coordinates": {"$ref": "#/$defs/polygon_coordinates"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "coordinates"],
          "properties": {
            "type": {"const": "MultiPolygon"},
            "coordinates": {
              "type": "array",
              "minItems": 1,
              "maxItems": 100000,
              "items": {"$ref": "#/$defs/polygon_coordinates"}
            }
          }
        }
      ]
    },
    "polygon_coordinates": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100000,
      "items": {
        "type": "array",
        "minItems": 4,
        "maxItems": 100000,
        "items": {"$ref": "#/$defs/position"}
      }
    },
    "position": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "prefixItems": [
        {"type": "number", "minimum": -180, "maximum": 180},
        {"type": "number", "minimum": -90, "maximum": 90}
      ],
      "items": false
    },
    "sha256": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64,
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
